<Window x:Class="CryptoTicker.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="加密貨幣行情" Width="900" Height="680" MinWidth="760" MinHeight="560"
        Loaded="OnLoaded" Closing="OnClosing">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <StackPanel Orientation="Horizontal">
      <TextBlock VerticalAlignment="Center" Text="交易對" Margin="0,0,6,0" />
      <TextBox x:Name="PairBox" Width="110" Text="BTC/USDT" />
      <Button Content="套用" Click="OnApply" />
      <TextBlock x:Name="PriceText" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Margin="16,0,0,0" />
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="Gray" Margin="12,0,0,0" />
    </StackPanel>
    <Grid Grid.Row="1" Margin="0,12,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0">
        <Canvas x:Name="ChartCanvas" MinHeight="340" Background="#FFFAFBFC" />
      </Border>
      <StackPanel Grid.Column="1">
        <TextBlock Text="分析結果" FontWeight="Bold" FontSize="16" />
        <ListBox x:Name="AnalysisList" MinHeight="165" Margin="0,6,0,8" />
        <Button Content="重新整理分析" Click="OnRefreshAnalysis" HorizontalAlignment="Left" />
        <TextBlock Text="來源狀態" FontWeight="Bold" FontSize="16" Margin="0,14,0,4" />
        <ListBox x:Name="SourceList" Height="100" />
        <TextBlock Text="AI 解讀" FontWeight="Bold" FontSize="16" Margin="0,14,0,4" />
        <TextBox x:Name="AiText" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Height="130" VerticalScrollBarVisibility="Auto" />
        <Button Content="產生 AI 解讀" Click="OnGenerateAi" HorizontalAlignment="Left" />
      </StackPanel>
    </Grid>
    <Expander Grid.Row="2" Header="設定" IsExpanded="False">
      <Grid Margin="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Margin="0,0,12,0">
          <TextBlock Text="自訂 REST 行情來源" FontWeight="Bold" />
          <TextBox x:Name="CustomNameBox" Margin="0,4" ToolTip="名稱" />
          <TextBox x:Name="CustomUrlBox" Margin="0,4" ToolTip="網址" />
          <TextBox x:Name="CustomPricePathBox" Margin="0,4" ToolTip="價格 JSON 路徑，例如 data.last" />
          <TextBox x:Name="CustomTimestampPathBox" Margin="0,4" ToolTip="時間 JSON 路徑（選填）" />
          <TextBox x:Name="CustomHeaderBox" Margin="0,4" ToolTip="秘密標頭名稱（選填）" />
          <TextBox x:Name="CustomCredentialBox" Margin="0,4" ToolTip="Windows 認證名稱" />
          <PasswordBox x:Name="CustomSecretBox" Margin="0,4" ToolTip="要保存的秘密（選填）" />
          <Button Content="儲存自訂來源" Click="OnSaveCustomSource" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="OpenAI 相容 API" FontWeight="Bold" />
          <TextBox x:Name="AiEndpointBox" Margin="0,4" ToolTip="端點或基底網址" />
          <TextBox x:Name="AiModelBox" Margin="0,4" ToolTip="模型名稱" />
          <TextBox x:Name="AiCredentialBox" Margin="0,4" ToolTip="Windows 認證名稱" />
          <PasswordBox x:Name="AiSecretBox" Margin="0,4" ToolTip="要保存的 API 金鑰（選填）" />
          <Button Content="儲存 AI 設定" Click="OnSaveAiSettings" HorizontalAlignment="Left" />
          <TextBlock Text="僅供資訊參考，不構成投資建議。" Foreground="DarkOrange" TextWrapping="Wrap" Margin="0,22,0,0" />
        </StackPanel>
      </Grid>
    </Expander>
  </Grid>
</Window>
